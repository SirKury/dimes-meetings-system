# PostgreSQL connection for Prisma and NestJS
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dimes_meetings?schema=public"

# Base authentication settings for API
JWT_SECRET="change-this-in-production"
JWT_EXPIRES_IN="1d"

# Seed bootstrap admin user
SEED_ADMIN_EMAIL="admin@dimes.local"
SEED_ADMIN_PASSWORD="ChangeMe123!"
SEED_ADMIN_FIRST_NAME="DIMES"
SEED_ADMIN_LAST_NAME="Superadmin"
