generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MeetingStatus {
  SCHEDULED
  COMPLETED
  CANCELED
}

enum AttendanceStatus {
  ATTENDED
  ABSENT
  EXCUSED
}

enum MinuteStatus {
  DRAFT
  FINAL
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Establishment {
  id            String         @id @default(uuid())
  name          String
  code          String?        @unique
  address       String?
  users         User[]
  meetings      Meeting[]
  participants  Participant[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([name])
}

model User {
  id                 String          @id @default(uuid())
  email              String          @unique
  passwordHash       String
  firstName          String
  lastName           String
  isActive           Boolean         @default(true)
  roleId             String
  establishmentId    String
  role               Role            @relation(fields: [roleId], references: [id], onDelete: Restrict)
  establishment      Establishment   @relation(fields: [establishmentId], references: [id], onDelete: Restrict)
  createdMeetings    Meeting[]       @relation("MeetingCreator")
  minuteAuthorings   MeetingMinute[] @relation("MinuteAuthor")
  participantRecords Participant[]
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([roleId])
  @@index([establishmentId])
}

model Meeting {
  id              String        @id @default(uuid())
  title           String
  description     String?
  scheduledAt     DateTime
  status          MeetingStatus @default(SCHEDULED)
  establishmentId String
  createdById     String
  establishment   Establishment @relation(fields: [establishmentId], references: [id], onDelete: Restrict)
  createdBy       User          @relation("MeetingCreator", fields: [createdById], references: [id], onDelete: Restrict)
  participants    Participant[]
  attendances     Attendance[]
  minute          MeetingMinute?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([establishmentId])
  @@index([createdById])
  @@index([scheduledAt])
}

model Participant {
  id              String         @id @default(uuid())
  meetingId       String
  userId          String?
  establishmentId String?
  fullName        String
  email           String?
  position        String?
  isExternal      Boolean        @default(false)
  meeting         Meeting        @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user            User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  establishment   Establishment? @relation(fields: [establishmentId], references: [id], onDelete: SetNull)
  attendances     Attendance[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([meetingId])
  @@index([userId])
  @@index([establishmentId])
}

model Attendance {
  id            String           @id @default(uuid())
  meetingId     String
  participantId String
  status        AttendanceStatus
  notes         String?
  meeting       Meeting          @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  participant   Participant      @relation(fields: [participantId], references: [id], onDelete: Cascade)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@unique([meetingId, participantId])
  @@index([meetingId])
  @@index([participantId])
}

model MeetingMinute {
  id           String       @id @default(uuid())
  meetingId    String       @unique
  objective    String
  agenda       String
  development  String
  agreements   String
  observations String?
  status       MinuteStatus @default(DRAFT)
  createdById  String
  meeting      Meeting      @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("MinuteAuthor", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([createdById])
}
